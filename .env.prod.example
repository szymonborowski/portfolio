# =============================================================================
# Production Environment Configuration
# Copy this file to .env.prod and fill in the values
#
# KLUCZE WEWNĘTRZNE — wspólne wartości dla wielu serwisów:
#   USERS_INTERNAL_API_KEY  — używany przez Users (walidacja) + Admin + Frontend + SSO (caller)
#   ANALYTICS_INTERNAL_API_KEY — używany przez Analytics (walidacja) + Frontend (caller)
#
# APP_KEY dla każdego serwisu generuj przez: php artisan key:generate --show
# =============================================================================

# ---------- GLOBAL ----------
DOMAIN=example.com
NETWORK_NAME=web

# ---------- SHARED INTERNAL API KEYS ----------
# Te klucze muszą być identyczne po obu stronach — serwis walidujący i wywołujący
USERS_INTERNAL_API_KEY=
ANALYTICS_INTERNAL_API_KEY=

# ---------- TRAEFIK ----------
TRAEFIK_DASHBOARD_DOMAIN=traefik.${DOMAIN}

# ---------- RABBITMQ ----------
RABBITMQ_USER=admin
RABBITMQ_PASS=
RABBITMQ_DOMAIN=rabbitmq.${DOMAIN}

# ---------- MONITORING ----------
GRAFANA_DOMAIN=grafana.${DOMAIN}
PROMETHEUS_DOMAIN=prometheus.${DOMAIN}
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ---------- FRONTEND ----------
FRONTEND_IMAGE=ghcr.io/szymonborowski/portfolio-frontend:sha-<SHORT_SHA>
FRONTEND_DOMAIN=${DOMAIN}
FRONTEND_APP_NAME=Portfolio
FRONTEND_APP_KEY=
FRONTEND_DB_DATABASE=frontend
FRONTEND_DB_USERNAME=frontend
FRONTEND_DB_PASSWORD=
FRONTEND_DB_ROOT_PASSWORD=
# SSO — musi zgadzać się z klientem zarejestrowanym w SSO
FRONTEND_SSO_URL=https://sso.${DOMAIN}
FRONTEND_SSO_API_URL_INTERNAL=http://sso-nginx
FRONTEND_SSO_CLIENT_ID=frontend-client
FRONTEND_SSO_CLIENT_SECRET=
# Wewnętrzne URL-e serwisów (domyślne wartości działają w Docker Compose)
FRONTEND_BLOG_API_URL_INTERNAL=http://blog-nginx
FRONTEND_USERS_API_URL_INTERNAL=http://users-nginx
FRONTEND_ANALYTICS_API_URL_INTERNAL=http://analytics-nginx

# ---------- SSO ----------
SSO_IMAGE=ghcr.io/szymonborowski/portfolio-sso:sha-<SHORT_SHA>
SSO_DOMAIN=sso.${DOMAIN}
SSO_APP_NAME=SSO
SSO_APP_KEY=
SSO_DB_DATABASE=sso
SSO_DB_USERNAME=sso
SSO_DB_PASSWORD=
SSO_DB_ROOT_PASSWORD=
# Users API — SSO weryfikuje hasła przez Users
SSO_USERS_API_URL_INTERNAL=http://users-nginx

# ---------- ADMIN ----------
ADMIN_IMAGE=ghcr.io/szymonborowski/portfolio-admin:sha-<SHORT_SHA>
ADMIN_DOMAIN=admin.${DOMAIN}
ADMIN_APP_NAME="Admin Panel"
ADMIN_APP_KEY=
ADMIN_DB_DATABASE=admin
ADMIN_DB_USERNAME=admin
ADMIN_DB_PASSWORD=
ADMIN_DB_ROOT_PASSWORD=
ADMIN_USERS_API_URL_INTERNAL=http://users-nginx
ADMIN_SSO_URL=https://sso.${DOMAIN}
ADMIN_SSO_INTERNAL_URL=http://sso-nginx
ADMIN_SSO_CLIENT_ID=admin-client
ADMIN_SSO_CLIENT_SECRET=
ADMIN_SSO_REDIRECT_URI=https://admin.${DOMAIN}/auth/sso/callback

# ---------- USERS ----------
USERS_IMAGE=ghcr.io/szymonborowski/portfolio-users:sha-<SHORT_SHA>
USERS_DOMAIN=users.${DOMAIN}
USERS_APP_NAME=Users
USERS_APP_KEY=
USERS_DB_DATABASE=users
USERS_DB_USERNAME=users
USERS_DB_PASSWORD=
USERS_DB_ROOT_PASSWORD=

# ---------- BLOG ----------
BLOG_IMAGE=ghcr.io/szymonborowski/portfolio-blog:sha-<SHORT_SHA>
BLOG_DOMAIN=blog.${DOMAIN}
BLOG_APP_NAME=Blog
BLOG_APP_KEY=
BLOG_DB_DATABASE=blog
BLOG_DB_USERNAME=blog
BLOG_DB_PASSWORD=
BLOG_DB_ROOT_PASSWORD=

# ---------- ANALYTICS ----------
ANALYTICS_IMAGE=ghcr.io/szymonborowski/portfolio-analytics:sha-<SHORT_SHA>
ANALYTICS_DB_DATABASE=analytics
ANALYTICS_DB_USERNAME=analytics
ANALYTICS_DB_PASSWORD=
ANALYTICS_DB_ROOT_PASSWORD=
